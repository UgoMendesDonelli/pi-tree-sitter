{
  "name": "pi-tree-sitter",
  "version": "0.1.0",
  "description": "Pi extension: Tree-sitter structural code analysis for the AI assistant — AST querying, directory analysis, docstring extraction, and dependency/call/inheritance graphs",
  "license": "MIT",
  "author": "Ugo Mendes Donelli <ugodonelli@hugowiz.it>",
  "main": "index.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/UgoMendesDonelli/pi-tree-sitter"
  },
  "keywords": [
    "pi-extension",
    "tree-sitter",
    "code-analysis",
    "ast",
    "static-analysis",
    "code-graph",
    "pi"
  ],
  "homepage": "https://github.com/UgoMendesDonelli/pi-tree-sitter#readme",
  "bugs": {
    "url": "https://github.com/UgoMendesDonelli/pi-tree-sitter/issues"
  },
  "type": "module",
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "typebox": "^1.1.38",
    "tree-sitter-c": "^0.23.0",
    "tree-sitter-css": "^0.23.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-html": "^0.23.0",
    "tree-sitter-javascript": "^0.23.0",
    "tree-sitter-python": "^0.23.0",
    "tree-sitter-ruby": "^0.23.0",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.0",
    "web-tree-sitter": "^0.26.9"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit --skipLibCheck 2>&1 | grep -v 'Cannot find module.*pi-coding-agent' || true",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  }
}
